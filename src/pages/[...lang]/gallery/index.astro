---
import GalleryComment from '@/components/Comment/GalleryComment.astro'
import { allLocales } from '@/config'
import { getLangFromLocale, getLangRouteParam } from '@/i18n/lang'
import { ui } from '@/i18n/ui'
import Layout from '@/layouts/Layout.astro'
import { getGalleryItems } from '@/utils/gallery'

export async function getStaticPaths() {
  return allLocales.map(lang => ({
    params: { lang: getLangRouteParam(lang) },
  }))
}

const currentLang = getLangFromLocale(Astro.currentLocale)
const currentUI = ui[currentLang]
const galleryLightboxUI = {
  de: {
    close: 'Galerie-Leuchtkasten schließen',
    previous: 'Zurück',
    previousAriaLabel: 'Vorheriges Galerieelement',
    next: 'Weiter',
    nextAriaLabel: 'Nächstes Galerieelement',
  },
  en: {
    close: 'Close gallery lightbox',
    previous: 'Previous',
    previousAriaLabel: 'Previous gallery item',
    next: 'Next',
    nextAriaLabel: 'Next gallery item',
  },
  es: {
    close: 'Cerrar visor de galería',
    previous: 'Anterior',
    previousAriaLabel: 'Elemento anterior de la galería',
    next: 'Siguiente',
    nextAriaLabel: 'Siguiente elemento de la galería',
  },
  fr: {
    close: 'Fermer la visionneuse de la galerie',
    previous: 'Précédent',
    previousAriaLabel: 'Élément précédent de la galerie',
    next: 'Suivant',
    nextAriaLabel: 'Élément suivant de la galerie',
  },
  ja: {
    close: 'ギャラリーライトボックスを閉じる',
    previous: '前へ',
    previousAriaLabel: '前のギャラリー項目',
    next: '次へ',
    nextAriaLabel: '次のギャラリー項目',
  },
  ko: {
    close: '갤러리 라이트박스 닫기',
    previous: '이전',
    previousAriaLabel: '이전 갤러리 항목',
    next: '다음',
    nextAriaLabel: '다음 갤러리 항목',
  },
  pl: {
    close: 'Zamknij widok galerii',
    previous: 'Poprzedni',
    previousAriaLabel: 'Poprzedni element galerii',
    next: 'Następny',
    nextAriaLabel: 'Następny element galerii',
  },
  pt: {
    close: 'Fechar visualizador da galeria',
    previous: 'Anterior',
    previousAriaLabel: 'Item anterior da galeria',
    next: 'Próximo',
    nextAriaLabel: 'Próximo item da galeria',
  },
  ru: {
    close: 'Закрыть лайтбокс галереи',
    previous: 'Предыдущий',
    previousAriaLabel: 'Предыдущий элемент галереи',
    next: 'Следующий',
    nextAriaLabel: 'Следующий элемент галереи',
  },
  zh: {
    close: '关闭相册灯箱',
    previous: '上一张',
    previousAriaLabel: '上一张相册图片',
    next: '下一张',
    nextAriaLabel: '下一张相册图片',
  },
  'zh-tw': {
    close: '關閉相簿燈箱',
    previous: '上一張',
    previousAriaLabel: '上一張相簿圖片',
    next: '下一張',
    nextAriaLabel: '下一張相簿圖片',
  },
} as const
const currentGalleryLightboxUI = galleryLightboxUI[currentLang]
const items = await getGalleryItems()
const getItemLabel = (item: Awaited<ReturnType<typeof getGalleryItems>>[number]) => item.metadataTitle || item.fileName
---

<Layout postTitle={currentUI.gallery}>
  <section>
    <div class="uno-decorative-line" />
    {items.length === 0 ? (
      <p class="mt-10.5 c-secondary leading-relaxed">{currentUI.galleryEmpty}</p>
    ) : (
      <>
        <div class="mt-10.5 columns-2 gap-8 md:columns-3 lg:columns-3">
          {items.map((item, index) => (
            <article class="mb-8 break-inside-avoid">
              <button
                type="button"
                class="block w-full cursor-pointer border-none bg-transparent p-0 text-left"
                data-gallery-trigger
                data-gallery-trigger-index={String(index)}
                data-gallery-image={item.imagePath}
                data-gallery-title={getItemLabel(item)}
                data-gallery-description={item.description}
                data-gallery-date={item.date ?? ''}
                data-gallery-comment-key={item.commentKey}
              >
                <img
                  src={item.imagePath}
                  alt={item.description || getItemLabel(item)}
                  class="w-full rounded-sm"
                  loading="lazy"
                />
              </button>
            </article>
          ))}
        </div>

        <div
          class="fixed inset-0 z-50 hidden items-center justify-center p-4"
          data-gallery-lightbox
          data-gallery-lightbox-current-index=""
          hidden
        >
          <button
            type="button"
            class="absolute inset-0 border-none bg-black/70 p-0"
            data-gallery-lightbox-close
            aria-label={currentGalleryLightboxUI.close}
          />
          <div
            class="relative z-1 flex max-h-full w-full max-w-6xl flex-col overflow-hidden rounded-sm bg-background px-6 py-6 shadow-xl lg:h-[min(90vh,56rem)]"
            role="dialog"
            aria-modal="true"
            aria-labelledby="gallery-lightbox-title"
            data-gallery-lightbox-dialog
            tabindex="-1"
          >
            <div class="mb-6 flex items-start justify-end gap-4">
              <button
                type="button"
                class="shrink-0 border-none bg-transparent p-0 text-2xl leading-none"
                data-gallery-lightbox-close
                aria-label={currentGalleryLightboxUI.close}
              >
                ×
              </button>
            </div>
            <div class="grid min-h-0 flex-1 gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(20rem,1fr)] lg:items-start">
              <section class="min-h-0 h-full flex flex-col lg:max-h-full" data-gallery-lightbox-image-panel>
                <div class="min-h-0 flex flex-1 items-center justify-center" data-gallery-lightbox-image-track>
                  <img
                    src=""
                    alt=""
                    class="h-auto w-auto max-h-full max-w-full rounded-sm object-contain lg:min-h-0"
                    data-gallery-lightbox-image
                  />
                </div>
                <div class="shrink-0 flex items-center justify-between gap-4 pt-4" data-gallery-lightbox-navigation>
                  <button
                    type="button"
                    class="highlight-hover border-none bg-transparent p-0 c-secondary transition-[colors,font-weight] after:bottom-0.15em hover:(c-primary font-bold) hover:text-foreground"
                    aria-label={currentGalleryLightboxUI.previousAriaLabel}
                    data-gallery-lightbox-previous
                  >
                    ← {currentGalleryLightboxUI.previous}
                  </button>
                  <button
                    type="button"
                    class="highlight-hover border-none bg-transparent p-0 c-secondary transition-[colors,font-weight] after:bottom-0.15em hover:(c-primary font-bold) hover:text-foreground"
                    aria-label={currentGalleryLightboxUI.nextAriaLabel}
                    data-gallery-lightbox-next
                  >
                    {currentGalleryLightboxUI.next} →
                  </button>
                </div>
              </section>
              <section class="min-h-0 flex flex-col rounded-sm bg-background/95 p-4 lg:max-h-full lg:overflow-y-auto" data-gallery-lightbox-panel-scroll>
                <section class="min-h-0" data-gallery-lightbox-meta>
                  <p id="gallery-lightbox-title" class="text-lg font-medium" data-gallery-lightbox-title />
                  <p class="mt-2 c-secondary leading-relaxed" data-gallery-lightbox-date />
                  <p class="mt-4 leading-relaxed" data-gallery-lightbox-description />
                </section>
                <section class="min-h-0 flex flex-1 flex-col pt-6" data-gallery-lightbox-comments>
                  <div class="min-h-0 flex-1 lg:max-h-full lg:overflow-y-auto" data-gallery-lightbox-comments-scroll>
                    {items[0] && <GalleryComment discussionTerm={items[0].commentKey} instanceId="lightbox" />}
                  </div>
                </section>
              </section>
            </div>
          </div>
        </div>

        <script is:inline>
          const lightbox = document.querySelector('[data-gallery-lightbox]')
          const lightboxImage = lightbox?.querySelector('[data-gallery-lightbox-image]')
          const lightboxTitle = lightbox?.querySelector('[data-gallery-lightbox-title]')
          const lightboxDate = lightbox?.querySelector('[data-gallery-lightbox-date]')
          const lightboxDescription = lightbox?.querySelector('[data-gallery-lightbox-description]')
          const triggerSelector = '[data-gallery-trigger]'
          const closeSelector = '[data-gallery-lightbox-close]'
          const previousSelector = '[data-gallery-lightbox-previous]'
          const nextSelector = '[data-gallery-lightbox-next]'
          const triggerElements = Array.from(document.querySelectorAll(triggerSelector)).filter(
            trigger => trigger instanceof HTMLButtonElement,
          )
          const galleryItems = triggerElements.map((trigger, index) => ({
            index,
            image: trigger.dataset.galleryImage || '',
            title: trigger.dataset.galleryTitle || '',
            description: trigger.dataset.galleryDescription || '',
            date: trigger.dataset.galleryDate || '',
            commentKey: trigger.dataset.galleryCommentKey || '',
          }))
          const lightboxDialog = lightbox?.querySelector('[data-gallery-lightbox-dialog]')
          const lightboxCloseButton = lightboxDialog?.querySelector(closeSelector)
          const lightboxPreviousButton = lightbox?.querySelector(previousSelector)
          const lightboxNextButton = lightbox?.querySelector(nextSelector)
          const focusableSelector = [
            'button:not([disabled])',
            'a[href]',
            'input:not([disabled])',
            'select:not([disabled])',
            'textarea:not([disabled])',
            '[tabindex]:not([tabindex="-1"])',
          ].join(', ')

          const lightboxCommentContainer = lightbox?.querySelector('[data-gallery-lightbox-comments] [data-comment-provider="giscus"]')
          let activeTrigger = null
          let currentIndex = -1
          let previousBodyOverflow = ''

          function getFocusableElements() {
            if (!(lightboxDialog instanceof HTMLElement)) {
              return []
            }

            return Array.from(lightboxDialog.querySelectorAll(focusableSelector)).filter(
              element => element instanceof HTMLElement && !element.hidden,
            )
          }

          function updateNavigationState() {
            if (!(lightboxPreviousButton instanceof HTMLButtonElement) || !(lightboxNextButton instanceof HTMLButtonElement)) {
              return
            }

            const hasItems = galleryItems.length > 1
            lightboxPreviousButton.disabled = !hasItems
            lightboxNextButton.disabled = !hasItems
          }

          function updateLightboxContentFromItem(item, index) {
            if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) {
              return
            }

            currentIndex = index
            lightbox.dataset.galleryLightboxCurrentIndex = currentIndex >= 0 ? String(currentIndex) : ''
            lightboxImage.src = item.image
            lightboxImage.alt = item.description || item.title

            if (lightboxTitle instanceof HTMLElement) {
              lightboxTitle.textContent = item.title
            }

            if (lightboxDate instanceof HTMLElement) {
              lightboxDate.textContent = item.date
              lightboxDate.hidden = !item.date
            }

            if (lightboxDescription instanceof HTMLElement) {
              lightboxDescription.textContent = item.description
              lightboxDescription.hidden = !item.description
            }

            if (lightboxCommentContainer instanceof HTMLElement && lightboxCommentContainer.dataset.config) {
              try {
                const commentConfig = JSON.parse(lightboxCommentContainer.dataset.config)
                lightboxCommentContainer.dataset.config = JSON.stringify({
                  ...commentConfig,
                  term: item.commentKey,
                })
              }
              catch (error) {
                console.error('[Gallery] Failed to update lightbox comment config:', error)
              }
            }

            updateNavigationState()

            if (!lightbox.hidden) {
              document.dispatchEvent(new CustomEvent('gallery-lightbox:open'))
            }
          }

          function updateLightboxContent(index) {
            const fallbackIndex = Number.isInteger(index) && index >= 0 ? index : 0
            const item = galleryItems[fallbackIndex]

            if (!item) {
              return
            }

            updateLightboxContentFromItem(item, fallbackIndex)
          }

          function navigateLightbox(step) {
            if (!(lightbox instanceof HTMLElement) || lightbox.hidden || galleryItems.length <= 1 || currentIndex < 0) {
              return
            }

            const nextIndex = (currentIndex + step + galleryItems.length) % galleryItems.length
            const nextItem = galleryItems[nextIndex]

            if (!nextItem) {
              return
            }

            updateLightboxContentFromItem(nextItem, nextIndex)
          }

          function closeLightbox() {
            if (!(lightbox instanceof HTMLElement)) {
              return
            }

            lightbox.hidden = true
            lightbox.classList.add('hidden')
            lightbox.classList.remove('flex')
            lightbox.dataset.galleryLightboxCurrentIndex = ''
            currentIndex = -1

            if (lightboxImage instanceof HTMLImageElement) {
              lightboxImage.src = ''
              lightboxImage.alt = ''
            }

            if (lightboxTitle instanceof HTMLElement) {
              lightboxTitle.textContent = ''
            }

            if (lightboxDate instanceof HTMLElement) {
              lightboxDate.textContent = ''
              lightboxDate.hidden = true
            }

            if (lightboxDescription instanceof HTMLElement) {
              lightboxDescription.textContent = ''
              lightboxDescription.hidden = true
            }

            document.body.style.overflow = previousBodyOverflow
            previousBodyOverflow = ''
            activeTrigger?.focus()
            activeTrigger = null
          }

          function openLightbox(trigger) {
            if (!(lightbox instanceof HTMLElement)) {
              return
            }

            activeTrigger = trigger
            const index = Number.parseInt(trigger.dataset.galleryTriggerIndex || '-1', 10)
            updateLightboxContent(Number.isNaN(index) ? -1 : index)

            lightbox.hidden = false
            lightbox.classList.remove('hidden')
            lightbox.classList.add('flex')
            document.dispatchEvent(new CustomEvent('gallery-lightbox:open'))
            previousBodyOverflow = document.body.style.overflow
            document.body.style.overflow = 'hidden'
            lightboxCloseButton?.focus()
            if (document.activeElement !== lightboxCloseButton) {
              lightboxDialog?.focus()
            }
          }

          triggerElements.forEach((trigger, index) => {
            trigger.addEventListener('click', (event) => {
              event.preventDefault()
              event.stopPropagation()
              openLightbox(trigger)
            })

            if (!trigger.dataset.galleryTriggerIndex) {
              trigger.dataset.galleryTriggerIndex = String(index)
            }
          })

          lightboxImage?.addEventListener('click', (event) => {
            event.preventDefault()
            event.stopPropagation()
          })

          lightboxPreviousButton?.addEventListener('click', (event) => {
            event.preventDefault()
            event.stopPropagation()
            navigateLightbox(-1)
          })

          lightboxNextButton?.addEventListener('click', (event) => {
            event.preventDefault()
            event.stopPropagation()
            navigateLightbox(1)
          })

          lightbox?.querySelectorAll(closeSelector).forEach((closeButton) => {
            closeButton.addEventListener('click', closeLightbox)
          })

          updateNavigationState()

          document.addEventListener('keydown', (event) => {
            if (!(lightbox instanceof HTMLElement) || lightbox.hidden) {
              return
            }

            if (event.key === 'Escape') {
              closeLightbox()
              return
            }

            if (event.key === 'ArrowLeft') {
              event.preventDefault()
              navigateLightbox(-1)
              return
            }

            if (event.key === 'ArrowRight') {
              event.preventDefault()
              navigateLightbox(1)
              return
            }

            if (event.key !== 'Tab' || !(lightboxDialog instanceof HTMLElement)) {
              return
            }

            const focusableElements = getFocusableElements()

            if (focusableElements.length === 0) {
              event.preventDefault()
              lightboxDialog.focus()
              return
            }

            const firstElement = focusableElements[0]
            const lastElement = focusableElements[focusableElements.length - 1]
            const activeElement = document.activeElement

            if (event.shiftKey) {
              if (activeElement === firstElement || !lightboxDialog.contains(activeElement)) {
                event.preventDefault()
                lastElement.focus()
              }

              return
            }

            if (activeElement === lastElement || !lightboxDialog.contains(activeElement)) {
              event.preventDefault()
              firstElement.focus()
            }
          })
        </script>
      </>
    )}
  </section>
</Layout>
